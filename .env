# ==============================================
# LMS Microservices — Environment Variables
# ==============================================

COMPOSE_PROJECT_NAME=lms

# --- Environment ---
ENVIRONMENT=development

# --- MySQL (shared instance, separate databases) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Auth Service DB
AUTH_DB_NAME=lms_auth
AUTH_DB_USER=lms_user
AUTH_DB_PASSWORD=lms_password

# Course Service DB
COURSE_DB_NAME=lms_courses
COURSE_DB_USER=lms_user
COURSE_DB_PASSWORD=lms_password

# Lesson Service DB
LESSON_DB_NAME=lms_lessons
LESSON_DB_USER=lms_user
LESSON_DB_PASSWORD=lms_password

# Progress Service DB
PROGRESS_DB_NAME=lms_progress
PROGRESS_DB_USER=lms_user
PROGRESS_DB_PASSWORD=lms_password

# Quiz Service DB
QUIZ_DB_NAME=lms_quiz
QUIZ_DB_USER=lms_user
QUIZ_DB_PASSWORD=lms_password

# --- JWT ---
JWT_SECRET=super-secret-lms-jwt-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Service Ports (host) ---
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Video Storage ---
VIDEO_STORAGE_PATH=/app/videos
